{
  "rewrites": [
    {
      "source": "/articles",
      "destination": "/"
    },
    {
      "source": "/articles/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
